  create view "finance_db"."dbt_dev"."stg_raw_responses_parsed__dbt_tmp"
    
    
  as (
    with source as (
    select * from "finance_db"."raw"."raw_api_responses"
    where raw_payload ? 'Time Series (Daily)'  -- skip error/rate-limit payloads
),

exploded as (
    select
        r.response_id,
        r.ticker,
        r.fetched_at,
        kv.key::date as trade_date,
        kv.value as day_payload
    from source r,
         jsonb_each(r.raw_payload -> 'Time Series (Daily)') as kv(key, value)
),

parsed as (
    select
        response_id,
        ticker,
        fetched_at,
        trade_date,
        (day_payload ->> '1. open')::numeric(12,4)   as open_price,
        (day_payload ->> '2. high')::numeric(12,4)   as high_price,
        (day_payload ->> '3. low')::numeric(12,4)    as low_price,
        (day_payload ->> '4. close')::numeric(12,4)  as close_price,
        (day_payload ->> '5. volume')::bigint        as volume
    from exploded
)

select * from parsed
  );
[0m14:56:08.162920 [debug] [Thread-1 (]: On model.finance_pipeline.stg_daily_prices: /* {"app": "dbt", "dbt_version": "1.12.0b3", "profile_name": "finance_pipeline", "target_name": "dev", "node_id": "model.finance_pipeline.stg_daily_prices"} */

  create view "finance_db"."dbt_dev"."stg_daily_prices__dbt_tmp"
    
    
  as (
    with source as (
    select * from "finance_db"."raw"."daily_prices"
),

cleaned as (
    select
        ticker,
        trade_date,
        open_price::numeric(12,4)   as open_price,
        high_price::numeric(12,4)   as high_price,
        low_price::numeric(12,4)    as low_price,
        close_price::numeric(12,4)  as close_price,
        volume::bigint              as volume,
        source_response_id,
        loaded_at
    from source
    where close_price > 0
      and high_price >= low_price   -- guard against impossible OHLC relationships
